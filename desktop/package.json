{
  "name": "voicedraft-desktop",
  "version": "1.0.0",
  "description": "VoiceDraft Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.voicedraft.app",
    "productName": "VoiceDraft",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "backend-dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "renderer/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "renderer/logo.png"
    }
  }
}
